# ============================================================================
# Plantilla de variables de entorno — copiar a `.env` y completar los valores.
# El archivo `.env` NUNCA debe subirse al repositorio (ver .gitignore).
# En CI, estos valores se inyectan mediante GitHub Secrets.
# ============================================================================

# Ambiente objetivo: define qué conjunto de URLs se usa (staging | prod).
TEST_ENV=prod

# --- Aplicación E2E (SauceDemo) ---
# URL base del sitio bajo prueba para el ambiente seleccionado.
E2E_BASE_URL_PROD=https://www.saucedemo.com
E2E_BASE_URL_STAGING=https://www.saucedemo.com

# Credenciales del usuario de prueba (en SauceDemo son públicas y visibles en la home).
SAUCE_USERNAME=standard_user
SAUCE_PASSWORD=secret_sauce

# --- API de integración (PokéAPI) ---
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# --- Ejecución ---
# Pokémon inicial de la cadena de evolución a validar en la prueba de integración.
POKEMON_UNDER_TEST=squirtle
